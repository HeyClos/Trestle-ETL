# Trestle WebAPI endpoints
TRESTLE_BASE_URL=https://api.cotality.com/trestle/odata/
TRESTLE_TOKEN_URL=https://api.cotality.com/trestle/oidc/connect/token

# Trestle OAuth2 client credentials
TRESTLE_CLIENT_ID=your-client-id-here
TRESTLE_CLIENT_SECRET=your-client-secret-here

# MySQL connection parameters
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=trestle
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=trestle

# Pipeline runtime configuration
STATE_FILE_PATH=sync_state.json
PAGE_SIZE=1000
